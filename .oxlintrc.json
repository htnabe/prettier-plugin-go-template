{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "sort-keys": "off",
    "no-restricted-imports": "off",
    "no-unused-labels": "error",
    "no-duplicate-imports": "error",
    "no-unused-expressions": "error"
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true
  }
}
