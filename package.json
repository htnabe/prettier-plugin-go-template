{
  "name": "@htnabe/prettier-plugin-go-template",
  "version": "0.0.1-rc.1",
  "description": "Prettier plugin for formatting Go & GoHugo templates.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/htnabe/prettier-plugin-go-template"
  },
  "author": {
    "name": "htnabe"
  },
  "keywords": [
    "prettier",
    "plugin",
    "go",
    "hugo",
    "gohugo",
    "template",
    "html"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "update:deps": "ncu -u && npm install",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:runtime": "npm run build && node -e \"import('./dist/index.mjs')\"",
    "coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --no-cache",
    "release:coverage": "npm run coverage",
    "release:plugin": "npm run test:runtime && npm run release:coverage && npm publish --provenance --access public",
    "watch:test": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "codecov": "^3.8.2",
    "jest": "^30.4.2",
    "lefthook": "^2.1.9",
    "npm-check-updates": "^22.2.3",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ulid": "^3.0.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  }
}
